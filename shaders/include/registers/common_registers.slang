[vk::binding(0, DESC_SET_PER_FRAME)] SamplerState COMMON_SAMPLERS[COMMON_SAMPLER_IDX::COUNT];
[vk::binding(1, DESC_SET_PER_FRAME)] Texture2D    COMMON_DBG_TEXTURES[COMMON_DBG_TEX_IDX::COUNT];

[vk::binding(2, DESC_SET_PER_FRAME)] ConstantBuffer<COMMON_CB_DATA> COMMON_CB;
[vk::binding(3, DESC_SET_PER_FRAME)] ConstantBuffer<COMMON_DBG_CB_DATA> COMMON_DBG_CB;

[vk::binding(4, DESC_SET_PER_FRAME)] ByteAddressBuffer COMMON_GEOM_STREAMS[COMMON_GEOM_STREAM_ID::COUNT];

[vk::binding(5, DESC_SET_PER_FRAME)] StructuredBuffer<COMMON_MESH_LOD>    COMMON_MESH_LOD_BUFFER;
