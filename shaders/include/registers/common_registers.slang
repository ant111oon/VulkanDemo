#define COMMON_DBG_USE_UNCHARTED_2_TONEMAPPING              DBG_BIT_VALUE(COMMON_DBG_CB.FLAGS_0, 3, false)
#define COMMON_DBG_USE_INDIRECT_LIGHTING                    DBG_BIT_VALUE(COMMON_DBG_CB.FLAGS_0, 4, false)
#define COMMON_DBG_IS_GEOM_GPU_FRUSTUM_CULLING_ENABLED      DBG_BIT_VALUE(COMMON_DBG_CB.FLAGS_0, 5, true)
#define COMMON_DBG_IS_GEOM_GPU_HZB_CULLING_ENABLED          DBG_BIT_VALUE(COMMON_DBG_CB.FLAGS_0, 6, true)

#define COMMON_DBG_FORCED_GEOM_LOD                          DBG_VALUE(COMMON_DBG_CB.FORCED_GEOM_LOD, 0)


#define COMMON_DBG_IS_GEOM_GPU_CULLING_ENABLED              (COMMON_DBG_IS_GEOM_GPU_FRUSTUM_CULLING_ENABLED || COMMON_DBG_IS_GEOM_GPU_HZB_CULLING_ENABLED)

