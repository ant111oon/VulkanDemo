[vk::binding(7, DESC_SET_PER_FRAME)] StructuredBuffer<COMMON_MATERIAL>    COMMON_MATERIALS;
[vk::binding(8, DESC_SET_PER_FRAME)] Texture2D                            COMMON_MTL_TEXTURES[];

[vk::binding(9, DESC_SET_PER_FRAME)] StructuredBuffer<COMMON_INST>       COMMON_INST_BUFFER;

[vk::binding(10, DESC_SET_PER_FRAME)] Texture2D COMMON_DEPTH;
[vk::binding(11, DESC_SET_PER_FRAME)] Texture2D COMMON_HZB;


#define GET_COMMON_SAMPLER(SMP_IDX) COMMON_SAMPLERS[(uint)(SMP_IDX)]


